{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "calendar-manager-py/manifest@1",
  "title": "manifest.json（job 產出紀錄）",
  "description": "build.py 每次執行的唯一產出紀錄。下游以 artifact id 引用產出、從這裡讀真實狀態（job.py list/path/verify/media）。tests/ 拿真實產出驗證此契約。",
  "type": "object",
  "required": ["schema", "job_id", "created_at", "job_dir", "subject", "artifacts"],
  "properties": {
    "schema": { "const": "calendar-manager-py/manifest@1" },
    "job_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "description": "ISO 8601（含時區）" },
    "job_dir": { "type": "string", "minLength": 1 },
    "subject": {
      "type": "object",
      "required": ["title", "year", "month"],
      "properties": {
        "title": { "type": "string" },
        "title_prefix": { "type": "string" },
        "year": { "type": "integer" },
        "month": { "type": "integer", "minimum": 1, "maximum": 12 },
        "source": { "type": "string" }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["artifact_id", "kind", "filename", "path", "rel_path",
                     "bytes", "sha256", "created_at"],
        "properties": {
          "artifact_id": { "type": "string" },
          "kind": { "enum": ["json", "html", "png"] },
          "filename": { "type": "string" },
          "path": { "type": "string" },
          "rel_path": { "type": "string" },
          "bytes": { "type": "integer", "minimum": 0 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "created_at": { "type": "string" },
          "verified": { "type": "boolean" },
          "verify": { "type": "object" }
        }
      }
    }
  }
}
