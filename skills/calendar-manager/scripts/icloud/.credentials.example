# Copy this file to `.credentials` (same folder) and fill in real values.
# `.credentials` is gitignored -- never commit real credentials.
#
# ICLOUD_APP_PASSWORD is an Apple ID "App-Specific Password", generated at
# appleid.apple.com -- NOT your normal Apple ID password. See
# ../../references/apple-calendar-setup.md for the full walkthrough.
ICLOUD_USERNAME=you@icloud.com
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
